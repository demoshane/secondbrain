{
  "name": "second-brain",
  // Prerequisites: ~/.config/second-brain/.env.host must exist before opening
  // this devcontainer — runArgs --env-file will hard-fail if the file is missing.
  // Copy .env.host.example to that path and fill in your secrets.
  "build": {
    "dockerfile": "Dockerfile"
  },
  // Mount repo at /workspace so engine/paths.py auto-detection works
  "workspaceFolder": "/workspace",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=cached",
  "features": {},
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "DavidAnson.vscode-markdownlint"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "terminal.integrated.cwd": "/workspace"
      }
    }
  },
  "mounts": [
    // Named volume for SQLite index — never Drive-synced, rebuildable
    "source=brain-index-data,target=/workspace/brain-index,type=volume",
    // Brain notes bind mount from ~/SecondBrain
    "source=${localEnv:HOME}/SecondBrain,target=/workspace/brain,type=bind,consistency=cached",
    // .env.host injected from outside the Drive-synced folder
    "source=${localEnv:HOME}/.config/second-brain/.env.host,target=/workspace/.env.host,type=bind,consistency=cached",
    // Claude OAuth credentials extracted from Keychain (by initializeCommand)
    "source=${localEnv:HOME}/.config/second-brain/claude-oauth.json,target=/home/vscode/.claude-oauth.json,type=bind,consistency=cached",
    // Claude Code state (onboarding flag etc)
    "source=${localEnv:HOME}/.claude.json,target=/home/vscode/.claude-auth-host/.claude.json,type=bind,consistency=cached",
    // Claude config — plugins, GSD, settings, commands, memory
    "source=${localEnv:HOME}/.claude,target=/home/vscode/.claude,type=bind,consistency=cached",
    // Git identity from host
    "source=${localEnv:HOME}/.gitconfig,target=/home/vscode/.gitconfig,type=bind,consistency=cached"
  ],
  "containerEnv": {
    // Container venv lives outside the bind-mounted workspace — keeps host .venv untouched
    "UV_PROJECT_ENVIRONMENT": "/home/vscode/.venv/second-brain"
  },
  // Runs on HOST before container starts — extracts Keychain credentials
  "initializeCommand": ".devcontainer/extract-claude-auth.sh",
  // OrbStack auto-scales memory from host RAM — no hard limits needed.
  // If OOM kills occur, check OrbStack resource settings.
  "runArgs": ["--env-file", "${localEnv:HOME}/.config/second-brain/.env.host"],
  "postCreateCommand": ".devcontainer/post-create.sh",
  "postStartCommand": ".devcontainer/post-start.sh",
  "remoteUser": "vscode"
}
