{
  "name": "second-brain",
  // Windows users: if brain mount fails, ${localEnv:HOME} may resolve to
  // Windows path. See README for WSL2 workaround.
  //
  // Prerequisites: ~/.config/second-brain/.env.host must exist before opening
  // this devcontainer — runArgs --env-file will hard-fail if the file is missing.
  // Copy .env.host.example to that path and fill in your secrets.
  "build": {
    "dockerfile": "Dockerfile"
  },
  "features": {},
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "DavidAnson.vscode-markdownlint"
      ]
    }
  },
  "mounts": [
    // Named volume for SQLite index — never Drive-synced, rebuildable
    "source=brain-index-data,target=/workspace/brain-index,type=volume",
    // Brain notes bind mount from ~/SecondBrain
    "source=${localEnv:HOME}/SecondBrain,target=/workspace/brain,type=bind,consistency=cached",
    // .env.host injected from outside the Drive-synced folder
    "source=${localEnv:HOME}/.config/second-brain/.env.host,target=/workspace/.env.host,type=bind,consistency=cached",
    // Claude config and auth across rebuilds
    "source=${localEnv:HOME}/.claude,target=/home/vscode/.claude,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.config/claude,target=/home/vscode/.config/claude,type=bind,consistency=cached",
    // Git identity from host
    "source=${localEnv:HOME}/.gitconfig,target=/home/vscode/.gitconfig,type=bind,consistency=cached"
  ],
  "runArgs": ["--env-file", "${localEnv:HOME}/.config/second-brain/.env.host"],
  "postCreateCommand": "sudo npm install -g @anthropic-ai/claude-code && uv pip install -e '.[dev]' && uv run pre-commit install",
  "postStartCommand": "sudo chown vscode:vscode /workspace/brain-index",
  "remoteUser": "vscode"
}
